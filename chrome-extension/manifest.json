{
  "manifest_version": 3,
  "name": "ATG 熱能柔光監控",
  "version": "2.1.0",
  "description": "只讀式讀取 ATG 房間資料，自動橋接網站並回傳高回報排名、爆破可能與高爆點數。",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://play.godeebxp.com/*",
    "https://*.github.io/*",
    "https://*.pages.dev/*",
    "https://*.netlify.app/*",
    "https://tntlinebotseemyeyes.online/*",
    "https://www.tntlinebotseemyeyes.online/*",
    "https://*.supabase.co/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ATG 熱能柔光"
  },
  "content_scripts": [
    {
      "matches": [
        "https://play.godeebxp.com/egames/*/game/*"
      ],
      "js": [
        "injected.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://play.godeebxp.com/egames/*/game/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://*.github.io/*",
        "https://*.pages.dev/*",
        "https://*.netlify.app/*",
        "https://tntlinebotseemyeyes.online/*",
        "https://www.tntlinebotseemyeyes.online/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "dashboard_bridge.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "version_name": "2.1.0 protected"
}